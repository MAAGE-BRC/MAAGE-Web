						<script>
							(function() {
								var slides = ['mock1-slide-events', 'mock1-slide-announcements'];
								var titles = ['Upcoming Events', 'Announcements'];
								var current = 0;

								function show(idx) {
									slides.forEach(function(id, i) {
										var el = document.getElementById(id);
										if (i === idx) {
											el.classList.add('mock1-carousel-slide--active');
										} else {
											el.classList.remove('mock1-carousel-slide--active');
										}
									});
									document.getElementById('mock1-carousel-title').textContent = titles[idx];
									document.getElementById('mock1-dot-0').className = 'mock1-carousel-dot' + (idx === 0 ? ' mock1-carousel-dot--active' : '');
									document.getElementById('mock1-dot-1').className = 'mock1-carousel-dot' + (idx === 1 ? ' mock1-carousel-dot--active' : '');
									current = idx;
								}

								document.getElementById('mock1-carousel-prev').addEventListener('click', function() {
									show(current === 0 ? slides.length - 1 : current - 1);
								});
								document.getElementById('mock1-carousel-next').addEventListener('click', function() {
									show(current === slides.length - 1 ? 0 : current + 1);
								});
								document.getElementById('mock1-dot-0').addEventListener('click', function() { show(0); });
								document.getElementById('mock1-dot-1').addEventListener('click', function() { show(1); });
							})();
						</script>

